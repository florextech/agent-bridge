{
  "name": "agent-bridge",
  "private": true,
  "version": "0.1.0",
  "description": "Multi-channel platform to connect code agents with messaging channels",
  "scripts": {
    "build": "pnpm -r build",
    "dev:api": "pnpm --filter @agent-bridge/api dev",
    "dev:web": "pnpm --filter @agent-bridge/web dev",
    "dev": "pnpm run dev:api & pnpm run dev:web",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "@nestjs/core", "@tailwindcss/oxide", "sharp"]
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  }
}
