# --- API ---
PORT=3001
DB_PATH=./agent-bridge.db

# --- Telegram ---
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
# Webhook URL: set this to your public URL + /telegram/webhook
