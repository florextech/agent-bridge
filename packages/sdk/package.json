  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/florextech/agent-bridge.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://github.com/florextech/agent-bridge",
  "dependencies": {
    "@agent-bridge/core": "workspace:*"
  },
  "engines": {
    "node": ">=20"
  }
