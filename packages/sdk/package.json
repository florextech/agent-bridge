{
  "name": "@agent-bridge/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for Agent Bridge — send notifications and check responses from code agents",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js"
